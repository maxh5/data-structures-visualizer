{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Java Project",
            "type": "shell",
            "command": "javac",
            "args": [
                "-d",
                "bin",
                "-cp",
                "C:/Program Files/Java/javafx-sdk-25.0.2/lib/*",
                "--module-path",
                "C:/Program Files/Java/javafx-sdk-25.0.2/lib",
                "--add-modules",
                "javafx.controls,javafx.fxml",
                "-sourcepath",
                "src",
                "src/dsv/App.java",
                "src/dsv/main/MainController.java",
                "src/dsv/map/MapController.java",
                "src/dsv/queue/QueueController.java",
                "src/dsv/set/SetController.java",
                "src/dsv/stack/StackController.java",
                "src/dsv/tree/TreeController.java"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$javac"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
