<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dsv.set.SetController">
   <top>
      <SplitPane dividerPositions="0.10101010101010101" orientation="VERTICAL" prefHeight="70.0" prefWidth="160.0" BorderPane.alignment="TOP_CENTER">
        <items>
            <Label fx:id="valueLabel" text="Set" />
            <HBox alignment="CENTER" maxHeight="50.0" prefHeight="50.0" prefWidth="698.0" spacing="15.0">
               <children>
                  <TextField fx:id="valueField" promptText="Value (no duplicates):" />
                  <Button mnemonicParsing="false" onAction="#add" text="Add" />
                  <Button mnemonicParsing="false" onAction="#remove" text="Remove" />
                  <Button mnemonicParsing="false" onAction="#search" text="Search" />
                  <Button mnemonicParsing="false" onAction="#clear" text="Clear" />
               </children>
            </HBox>
        </items>
      </SplitPane>
   </top>
   <center>
      <Pane fx:id="setPane" BorderPane.alignment="CENTER" maxWidth="Infinity" maxHeight="Infinity" />
   </center>
</BorderPane>
