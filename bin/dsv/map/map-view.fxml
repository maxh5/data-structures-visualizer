<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dsv.map.MapController">
   <top>
      <SplitPane dividerPositions="0.10101010101010101" orientation="VERTICAL" prefHeight="70.0" prefWidth="160.0" BorderPane.alignment="TOP_CENTER">
        <items>
            <Label fx:id="valueLabel" text="Map" />
            <HBox fx:id="controlBox" alignment="CENTER" maxHeight="50.0" prefHeight="50.0" prefWidth="698.0" spacing="15.0">
               <children>
                  <TextField fx:id="keyField" promptText="Key (String)" />
                  <TextField fx:id="valueField" promptText="Value (Int)" />
                  <Button mnemonicParsing="false" onAction="#add" text="Add" />
                  <Button mnemonicParsing="false" onAction="#remove" text="Remove" />
                  <Button mnemonicParsing="false" onAction="#search" text="Search" />
                  <Button mnemonicParsing="false" onAction="#clear" text="Clear" />
               </children>
            </HBox>
        </items>
      </SplitPane>
   </top>
   <center>
      <HBox BorderPane.alignment="CENTER" maxWidth="Infinity" maxHeight="Infinity">
         <children>
            <VBox prefHeight="200.0" prefWidth="100.0">
               <children>
                  <StackPane fx:id="indexPane0" alignment="CENTER_RIGHT" prefHeight="150.0" prefWidth="200.0"><Label text="Bucket 0" /></StackPane>
                  <StackPane fx:id="indexPane1" alignment="CENTER_RIGHT" prefHeight="150.0" prefWidth="200.0"><Label text="Bucket 1" /></StackPane>
                  <StackPane fx:id="indexPane2" alignment="CENTER_RIGHT" prefHeight="150.0" prefWidth="200.0"><Label text="Bucket 2" /></StackPane>
                  <StackPane fx:id="indexPane3" alignment="CENTER_RIGHT" prefHeight="150.0" prefWidth="200.0"><Label text="Bucket 3" /></StackPane>
                  <StackPane fx:id="indexPane4" alignment="CENTER_RIGHT" prefHeight="150.0" prefWidth="200.0"><Label text="Bucket 4" /></StackPane>
                  <StackPane fx:id="indexPane5" alignment="CENTER_RIGHT" prefHeight="150.0" prefWidth="200.0"><Label text="Bucket 5" /></StackPane>
                  <StackPane fx:id="indexPane6" alignment="CENTER_RIGHT" prefHeight="150.0" prefWidth="200.0"><Label text="Bucket 6" /></StackPane>
                  <StackPane fx:id="indexPane7" alignment="CENTER_RIGHT" prefHeight="150.0" prefWidth="200.0"><Label text="Bucket 7" /></StackPane>
               </children>
            </VBox>
            <VBox prefHeight="430.0" prefWidth="599.0">
               <children>
                  <HBox fx:id="bucket0" prefHeight="100.0" prefWidth="200.0" />
                  <HBox fx:id="bucket1" prefHeight="100.0" prefWidth="200.0" />
                  <HBox fx:id="bucket2" prefHeight="100.0" prefWidth="200.0" />
                  <HBox fx:id="bucket3" prefHeight="100.0" prefWidth="200.0" />
                  <HBox fx:id="bucket4" prefHeight="100.0" prefWidth="200.0" />
                  <HBox fx:id="bucket5" prefHeight="100.0" prefWidth="200.0" />
                  <HBox fx:id="bucket6" prefHeight="100.0" prefWidth="200.0" />
                  <HBox fx:id="bucket7" prefHeight="100.0" prefWidth="200.0" />
                  <HBox prefHeight="100.0" prefWidth="200.0" />
               </children>
            </VBox>
         </children>
      </HBox>
   </center>
</BorderPane>
